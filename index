<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Matrices</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            background-image: radial-gradient(circle at 50% 50%, #f1f5f9 0%, #f8fafc 100%);
        }
        .mono { font-family: 'JetBrains Mono', monospace; }
        
        /* FORZAR FILA HORIZONTAL ÚNICA */
        .equation-container {
            display: flex;
            flex-direction: row;
            flex-wrap: nowrap; /* Evita que los elementos se bajen */
            align-items: center;
            justify-content: center;
            gap: 1rem;
            min-width: max-content; /* Obliga al contenedor a ser tan ancho como sus hijos */
            padding: 1rem;
        }

        .matrix-cell {
            width: 55px;
            height: 45px;
            text-align: center;
            font-weight: 700;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            transition: all 0.2s;
            font-size: 0.85rem;
        }
        .matrix-cell:focus {
            outline: none;
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
            transform: translateY(-2px);
        }

        .btn-calc {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            transition: all 0.3s;
        }
        .btn-calc:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(0,0,0,0.1);
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.5);
            border-radius: 2rem;
        }

        .custom-scroll::-webkit-scrollbar { height: 6px; }
        .custom-scroll::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    </style>
</head>
<body class="p-4 md:p-8 min-h-screen text-slate-800">

    <div class="max-w-5xl mx-auto">
        <!-- Panel Superior -->
        <div class="glass-panel p-6 shadow-xl mb-8">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Tamaño</label>
                    <select id="matrixSize" class="w-full p-3 rounded-xl border border-slate-200 bg-white font-bold outline-none cursor-pointer">
                        <option value="2">2 x 2</option>
                        <option value="3" selected>3 x 3</option>
                        <option value="4">4 x 4</option>
                        <option value="5">5 x 5</option>
                        <option value="6">6 x 6</option>
                    </select>
                </div>
                <div>
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest block mb-2">Método</label>
                    <select id="method" class="w-full p-3 rounded-xl border border-slate-200 bg-white font-bold outline-none cursor-pointer">
                        <option value="doolittle">Doolittle (Lii = 1)</option>
                        <option value="crout">Crout (Uii = 1)</option>
                        <option value="cholesky">Cholesky (A = LLᵀ)</option>
                    </select>
                </div>
                <div class="flex items-end">
                    <button onclick="calculate()" class="btn-calc w-full py-3 text-white font-bold rounded-xl tracking-wider">
                        CALCULAR SISTEMA
                    </button>
                </div>
            </div>

            <!-- ÁREA CALCULADORA: SIEMPRE HORIZONTAL -->
            <div class="custom-scroll overflow-x-auto bg-slate-50/50 rounded-3xl border border-slate-100 p-4">
                <div class="equation-container">
                    <!-- Matriz A -->
                    <div class="flex flex-col items-center">
                        <div id="matrixAContainer" class="grid gap-2"></div>
                    </div>

                    <div class="text-3xl text-slate-300 font-thin">×</div>

                    <!-- Vector X labels -->
                    <div class="flex flex-col gap-2" id="vectorXPlaceholders"></div>

                    <div class="text-3xl text-slate-300 font-thin">=</div>

                    <!-- Vector B -->
                    <div class="flex flex-col gap-2" id="vectorBContainer"></div>
                </div>
            </div>

            <div class="mt-6 flex justify-center gap-6">
                <button onclick="loadExample()" class="text-xs font-bold text-blue-600 hover:underline tracking-tight flex items-center gap-1">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z"></path></svg>
                    Cargar Ejemplo 3x3
                </button>
                <button onclick="clearInputs()" class="text-xs font-bold text-slate-400 hover:text-red-500 uppercase tracking-widest">Limpiar</button>
            </div>
        </div>

        <!-- Resultados -->
        <div id="results" class="hidden space-y-6">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-6 rounded-3xl shadow-lg border border-slate-50">
                    <h3 class="text-xs font-black text-slate-400 uppercase mb-4 tracking-widest">Matriz L</h3>
                    <div id="resL" class="mono text-xs overflow-x-auto text-blue-600"></div>
                </div>
                <div class="bg-white p-6 rounded-3xl shadow-lg border border-slate-50">
                    <h3 class="text-xs font-black text-slate-400 uppercase mb-4 tracking-widest">Matriz U</h3>
                    <div id="resU" class="mono text-xs overflow-x-auto text-indigo-600"></div>
                </div>
            </div>

            <div class="bg-slate-900 rounded-[2.5rem] p-8 shadow-2xl text-white">
                <div class="flex items-center justify-between mb-8 border-b border-slate-800 pb-4">
                    <h3 class="text-xl font-black uppercase tracking-tighter">Vector Solución (x)</h3>
                    <div class="text-[10px] font-bold text-slate-500 px-3 py-1 bg-slate-800 rounded-full tracking-widest uppercase">Resultado Final</div>
                </div>
                
                <div id="resX" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mono mb-8"></div>

                <div class="pt-6 border-t border-slate-800">
                    <p class="text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-4">Comprobación A·x</p>
                    <div id="resCheck" class="flex flex-wrap gap-3"></div>
                </div>
            </div>

            <div id="errorBox" class="hidden bg-red-50 border-2 border-red-100 text-red-700 p-6 rounded-3xl flex gap-4 items-center">
                <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center flex-shrink-0">!</div>
                <p id="errorMessage" class="font-bold text-sm"></p>
            </div>
        </div>
    </div>

    <script>
        const matrixSizeSelect = document.getElementById('matrixSize');
        const matrixAContainer = document.getElementById('matrixAContainer');
        const vectorBContainer = document.getElementById('vectorBContainer');
        const vectorXPlaceholders = document.getElementById('vectorXPlaceholders');
        const resultsDiv = document.getElementById('results');

        function createGrids() {
            const n = parseInt(matrixSizeSelect.value);
            matrixAContainer.innerHTML = '';
            vectorBContainer.innerHTML = '';
            vectorXPlaceholders.innerHTML = '';
            
            matrixAContainer.style.gridTemplateColumns = `repeat(${n}, 55px)`;

            for (let i = 0; i < n; i++) {
                for (let j = 0; j < n; j++) {
                    const input = document.createElement('input');
                    input.type = 'number';
                    input.step = 'any';
                    input.id = `a_${i}_${j}`;
                    input.className = "matrix-cell";
                    matrixAContainer.appendChild(input);
                }
                const bInput = document.createElement('input');
                bInput.type = 'number';
                bInput.step = 'any';
                bInput.id = `b_${i}`;
                bInput.className = "matrix-cell !border-emerald-200 !text-emerald-700";
                vectorBContainer.appendChild(bInput);

                const xLabel = document.createElement('div');
                xLabel.className = "w-[55px] h-[45px] flex items-center justify-center font-bold text-slate-300 text-[10px] bg-slate-50 rounded-xl border border-slate-100 uppercase";
                xLabel.innerText = `x${i+1}`;
                vectorXPlaceholders.appendChild(xLabel);
            }
        }

        function loadExample() {
            matrixSizeSelect.value = "3";
            createGrids();
            const a = [[3, -0.1, -0.2], [0.1, 7, -0.3], [0.3, -0.2, 10]];
            const b = [7.85, -19.3, 71.4];
            for(let i=0; i<3; i++) {
                for(let j=0; j<3; j++) document.getElementById(`a_${i}_${j}`).value = a[i][j];
                document.getElementById(`b_${i}`).value = b[i];
            }
            calculate();
        }

        function clearInputs() {
            document.querySelectorAll('input').forEach(input => input.value = '');
            resultsDiv.classList.add('hidden');
        }

        function formatVal(val) {
            if (Math.abs(val) < 1e-10) return "0";
            return val.toFixed(6).replace(/\.?0+$/, "");
        }

        function calculate() {
            const n = parseInt(matrixSizeSelect.value);
            const method = document.getElementById('method').value;
            const A = [];
            const b = [];

            try {
                for (let i = 0; i < n; i++) {
                    A[i] = [];
                    for (let j = 0; j < n; j++) {
                        const v = parseFloat(document.getElementById(`a_${i}_${j}`).value);
                        if (isNaN(v)) throw new Error(`Falta valor en A[${i+1}][${j+1}]`);
                        A[i][j] = v;
                    }
                    const bv = parseFloat(document.getElementById(`b_${i}`).value);
                    if (isNaN(bv)) throw new Error(`Falta valor en b[${i+1}]`);
                    b[i] = bv;
                }

                let L = Array.from({ length: n }, () => Array(n).fill(0));
                let U = Array.from({ length: n }, () => Array(n).fill(0));

                if (method === 'doolittle') {
                    for (let i = 0; i < n; i++) {
                        for (let k = i; k < n; k++) {
                            let s = 0;
                            for (let j = 0; j < i; j++) s += (L[i][j] * U[j][k]);
                            U[i][k] = A[i][k] - s;
                        }
                        for (let k = i; k < n; k++) {
                            if (i === k) L[i][i] = 1;
                            else {
                                let s = 0;
                                for (let j = 0; j < i; j++) s += (L[k][j] * U[j][i]);
                                if (Math.abs(U[i][i]) < 1e-15) throw new Error("Pivote nulo.");
                                L[k][i] = (A[k][i] - s) / U[i][i];
                            }
                        }
                    }
                } else if (method === 'crout') {
                    for (let j = 0; j < n; j++) {
                        for (let i = j; i < n; i++) {
                            let s = 0;
                            for (let k = 0; k < j; k++) s += L[i][k] * U[k][j];
                            L[i][j] = A[i][j] - s;
                        }
                        for (let i = j; i < n; i++) {
                            if (i === j) U[i][i] = 1;
                            else {
                                let s = 0;
                                for (let k = 0; k < j; k++) s += L[j][k] * U[k][i];
                                if (Math.abs(L[j][j]) < 1e-15) throw new Error("Pivote nulo.");
                                U[j][i] = (A[j][i] - s) / L[j][j];
                            }
                        }
                    }
                } else if (method === 'cholesky') {
                    for (let i = 0; i < n; i++) {
                        for (let j = 0; j <= i; j++) {
                            let s = 0;
                            for (let k = 0; k < j; k++) s += L[i][k] * L[j][k];
                            if (i === j) {
                                let v = A[i][i] - s;
                                if (v < 0) throw new Error("No definida positiva.");
                                L[i][j] = Math.sqrt(v);
                            } else L[i][j] = (A[i][j] - s) / L[j][j];
                        }
                    }
                    for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) U[i][j] = L[j][i];
                }

                const y = Array(n).fill(0);
                for (let i = 0; i < n; i++) {
                    let s = 0;
                    for (let j = 0; j < i; j++) s += L[i][j] * y[j];
                    y[i] = (b[i] - s) / L[i][i];
                }

                const x = Array(n).fill(0);
                for (let i = n - 1; i >= 0; i--) {
                    let s = 0;
                    for (let j = i + 1; j < n; j++) s += U[i][j] * x[j];
                    x[i] = (y[i] - s) / U[i][i];
                }

                const renderTable = (m) => `<table class="w-full text-center">` + m.map(row => `<tr>` + row.map(v => `<td class="p-2 border border-slate-50 font-bold">${formatVal(v)}</td>`).join('') + `</tr>`).join('') + `</table>`;
                document.getElementById('resL').innerHTML = renderTable(L);
                document.getElementById('resU').innerHTML = renderTable(U);
                
                document.getElementById('resX').innerHTML = x.map((v, i) => `
                    <div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10 group hover:border-blue-500/50 transition-all">
                        <span class="text-slate-500 text-[10px] font-black uppercase">x${i+1}</span>
                        <span class="text-white text-xl font-bold">${formatVal(v)}</span>
                    </div>`).join('');

                let checkHtml = "";
                for(let i=0; i<n; i++) {
                    let sum = 0;
                    for(let j=0; j<n; j++) sum += A[i][j] * x[j];
                    checkHtml += `<div class="px-3 py-1.5 bg-slate-800 rounded-lg text-[10px] border border-slate-700 text-slate-400">b${i+1}: <span class="text-emerald-400 font-bold">${formatVal(sum)}</span></div>`;
                }
                document.getElementById('resCheck').innerHTML = checkHtml;

                document.getElementById('errorBox').classList.add('hidden');
                resultsDiv.classList.remove('hidden');
                resultsDiv.scrollIntoView({ behavior: 'smooth' });

            } catch (e) {
                document.getElementById('errorMessage').innerText = e.message;
                document.getElementById('errorBox').classList.remove('hidden');
                resultsDiv.classList.remove('hidden');
            }
        }

        matrixSizeSelect.addEventListener('change', createGrids);
        window.onload = createGrids;
    </script>
</body>
</html>
